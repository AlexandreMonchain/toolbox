{% extends 'base.html.twig' %}

{% block title %}BurnNote — Secret{% endblock %}

{% block body %}
    {# viewsRemaining : NULL = illimité, >0 = vues restantes, 0 = détruit #}
    {% set unlimited = viewsRemaining is null %}
    {% set available = unlimited or viewsRemaining > 0 %}
    <section class="hero-section">
        <div class="hero-icon">🔥</div>
        <h1 class="hero-title">Votre secret</h1>
        <p class="hero-subtitle">
            {% if unlimited %}
                Ce secret restera accessible jusqu'à son expiration.
            {% elseif viewsRemaining > 0 %}
                Il reste {{ viewsRemaining }} vue{{ viewsRemaining > 1 ? 's' : '' }} avant destruction.
            {% else %}
                Ce secret vient d'être détruit. Il n'est plus accessible.
            {% endif %}
        </p>
    </section>

    <div class="container" style="max-width: 640px;">
        <div class="card-modern">

            {# ── Badges vues + temps restant (tant que la note est accessible) ── #}
            {% if available %}
            <div class="d-flex gap-3 mb-3 flex-wrap">
                <span class="bn-badge">
                    <i class="fas fa-eye fa-fw" aria-hidden="true"></i>
                    {% if unlimited %}
                        Vues illimitées
                    {% else %}
                        {{ viewsRemaining }} vue{{ viewsRemaining > 1 ? 's' : '' }} restante{{ viewsRemaining > 1 ? 's' : '' }}
                    {% endif %}
                </span>
                <span class="bn-badge" id="bn-time-badge">
                    <i class="fas fa-clock fa-fw" aria-hidden="true"></i>
                    <span id="bn-countdown">…</span>
                </span>
            </div>
            {% endif %}

            <label class="form-label d-flex align-items-center gap-2">
                Secret
                <span class="text-muted" style="font-size:0.78rem; font-weight:400;" id="blur-hint">
                    <i class="fas fa-eye-slash fa-fw" aria-hidden="true"></i> Cliquez pour révéler
                </span>
            </label>

            <div class="d-flex gap-2 align-items-start">

                <div class="secret-wrapper flex-grow-1">
                    <div
                        id="secret-value"
                        class="form-control secret-blurred"
                        style="min-height: 130px; display: flex; align-items: center; justify-content: center; text-align: center; word-break: break-all; white-space: pre-wrap; cursor: pointer;"
                        aria-label="Contenu du secret (flouté par défaut)"
                    >{{ secret }}</div>
                    <textarea id="secret-raw" style="display:none" readonly aria-hidden="true">{{ secret }}</textarea>
                    <div class="secret-reveal-overlay" id="reveal-overlay" tabindex="0" role="button" aria-label="Révéler le secret">
                        <i class="fas fa-eye fa-lg" aria-hidden="true"></i>
                        <span>Cliquer pour révéler</span>
                    </div>
                </div>

                <button class="btn btn-secondary flex-shrink-0" id="copy-btn" title="Copier le secret">
                    <i class="fas fa-copy" aria-hidden="true"></i>
                </button>
            </div>

            <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
                <a href="{{ path('burnnote_index') }}" class="btn btn-outline-primary">
                    <i class="fas fa-plus" aria-hidden="true"></i> Créer un BurnNote
                </a>
                {% if available %}
                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#burnModal">
                    <i class="fas fa-fire" aria-hidden="true"></i> Burn this note
                </button>
                {% endif %}
            </div>

        </div>

        <p class="text-muted text-center mt-3" style="font-size: 0.8rem;">
            <i class="fas fa-fire" aria-hidden="true"></i>
            {% if unlimited %}
                Ce secret sera supprimé à son expiration.
            {% elseif viewsRemaining > 0 %}
                Ce secret sera supprimé après la dernière vue.
            {% else %}
                Ce secret a été définitivement supprimé de nos serveurs.
            {% endif %}
        </p>
    </div>

    {% if available %}
    <div class="modal fade" id="burnModal" tabindex="-1" aria-labelledby="burnModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border: 1px solid var(--color-border); border-radius: 16px; box-shadow: var(--shadow-hover);">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title" id="burnModalLabel" style="color: var(--color-text-primary);">
                        <i class="fas fa-fire text-danger"></i> Confirmer la suppression
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body" style="color: var(--color-text-secondary);">
                    Êtes-vous sûr de vouloir supprimer définitivement ce secret ? Cette action est irréversible.
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <form method="POST" action="{{ path('burnnote_burn', {token: token}) }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('burnnote_burn') }}">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-fire" aria-hidden="true"></i> Supprimer maintenant
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
{% endblock %}

{% block script %}
<script nonce="{{ csp_nonce() }}">
(function () {

    /* ── Reveal / blur ──────────────────────────────────────────────────── */
    const field   = document.getElementById('secret-value');
    const raw     = document.getElementById('secret-raw');
    const overlay = document.getElementById('reveal-overlay');
    const hint    = document.getElementById('blur-hint');

    function reveal() {
        field.classList.remove('secret-blurred');
        overlay.style.display = 'none';
        if (hint) hint.innerHTML = '<i class="fas fa-eye-slash fa-fw" aria-hidden="true"></i> Cliquer pour flouter';
    }

    function reblur() {
        field.classList.add('secret-blurred');
        overlay.style.display = '';
        if (hint) hint.innerHTML = '<i class="fas fa-eye-slash fa-fw" aria-hidden="true"></i> Cliquez pour révéler';
    }

    overlay.addEventListener('click', reveal);
    overlay.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); reveal(); }
    });

    field.addEventListener('click', function () {
        if (!field.classList.contains('secret-blurred')) reblur();
    });

    /* ── Copier ─────────────────────────────────────────────────────────── */
    const btn = document.getElementById('copy-btn');
    btn.addEventListener('click', () => {
        navigator.clipboard.writeText(raw.value).then(() => {
            btn.innerHTML = '<i class="fas fa-check" aria-hidden="true"></i>';
            btn.classList.replace('btn-secondary', 'btn-success');
            setTimeout(() => {
                btn.innerHTML = '<i class="fas fa-copy" aria-hidden="true"></i>';
                btn.classList.replace('btn-success', 'btn-secondary');
            }, 2000);
        }).catch(() => {});
    });

    /* ── Countdown ─────────────────────────────────────────────────────── */
    {% if available %}
    (function () {
        const EXPIRES_TS = {{ expiresAt.timestamp }};

        function fmtCountdown(nowS) {
            const diff = EXPIRES_TS - nowS;
            if (diff <= 0) return null;
            const h = Math.floor(diff / 3600);
            const m = Math.floor((diff % 3600) / 60);
            const s = diff % 60;
            if (h > 0) return `Expire dans ${h}h ${String(m).padStart(2, '0')}min`;
            if (m > 0) return `Expire dans ${m}min ${String(s).padStart(2, '0')}s`;
            return `Expire dans ${s}s`;
        }

        const el    = document.getElementById('bn-countdown');
        const badge = document.getElementById('bn-time-badge');

        function tick() {
            const label = fmtCountdown(Math.floor(Date.now() / 1000));
            if (label === null) {
                el.textContent = 'Expiré';
                if (badge) badge.style.opacity = '0.5';
                return;
            }
            el.textContent = label;
            setTimeout(tick, 1000);
        }

        tick();
    })();
    {% endif %}

})();
</script>
{% endblock %}
