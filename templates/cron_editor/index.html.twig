{% extends 'base.html.twig' %}

{% block title %}Éditeur de cron — Toolbox{% endblock %}
{% block meta_description %}Composez et déchiffrez vos expressions cron : traduction en français et prochaines dates d'exécution en temps réel. Simple et 100 % en ligne.{% endblock %}
{% block og_title %}Éditeur de cron — Toolbox{% endblock %}
{% block og_description %}Composez et comprenez vos expressions cron. Builder interactif, description en français, prochaines exécutions.{% endblock %}

{% block body %}
<section class="hero-section">
    <div class="hero-icon">⏱</div>
    <h1 class="hero-title">Éditeur de cron</h1>
    <p class="hero-subtitle">Composez vos expressions cron, obtenez la traduction en français et les prochaines exécutions.</p>
</section>

<div class="container" style="max-width:780px;">

    {# ── Expression principale ───────────────────────────────────────── #}
    <div class="card-modern mb-3">
        <label class="form-label" style="font-size:0.8rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; color:var(--color-text-secondary);">Expression cron</label>
        <div class="d-flex gap-2 align-items-center mb-2">
            <input type="text" id="cron-expr" class="form-control" value="0 * * * *"
                   placeholder="min heure j/mois mois j/sem"
                   style="font-family:monospace; font-size:1.05rem; letter-spacing:0.05em; max-width:300px;"
                   spellcheck="false" autocomplete="off">
            <button class="btn btn-sm btn-outline-secondary" id="cron-copy" title="Copier l'expression">
                <i class="fas fa-copy" aria-hidden="true"></i>
            </button>
        </div>

        <div id="cron-desc" class="cron-desc-box" aria-live="polite"></div>

        <div class="cron-fields-row mt-3" id="cron-fields-row">
            <div class="cron-field" id="cf-min">
                <div class="cron-field-label">Minute</div>
                <div class="cron-field-val" id="cfv-min">0</div>
                <div class="cron-field-hint">0–59</div>
            </div>
            <div class="cron-sep">:</div>
            <div class="cron-field" id="cf-hour">
                <div class="cron-field-label">Heure</div>
                <div class="cron-field-val" id="cfv-hour">*</div>
                <div class="cron-field-hint">0–23</div>
            </div>
            <div class="cron-sep">·</div>
            <div class="cron-field" id="cf-dom">
                <div class="cron-field-label">Jour/mois</div>
                <div class="cron-field-val" id="cfv-dom">*</div>
                <div class="cron-field-hint">1–31</div>
            </div>
            <div class="cron-sep">·</div>
            <div class="cron-field" id="cf-month">
                <div class="cron-field-label">Mois</div>
                <div class="cron-field-val" id="cfv-month">*</div>
                <div class="cron-field-hint">1–12</div>
            </div>
            <div class="cron-sep">·</div>
            <div class="cron-field" id="cf-dow">
                <div class="cron-field-label">Jour/sem</div>
                <div class="cron-field-val" id="cfv-dow">*</div>
                <div class="cron-field-hint">0=dim, 7=dim</div>
            </div>
        </div>
    </div>

    {# ── Prochaines exécutions ────────────────────────────────────────── #}
    <div class="card-modern mb-3">
        <h2 class="card-title" style="margin-bottom:0.75rem;">
            <i class="fas fa-clock-rotate-left fa-fw" aria-hidden="true"></i>
            Prochaines exécutions
        </h2>
        <ol id="cron-next" class="cron-next-list" aria-live="polite"></ol>
    </div>

    {# ── Builder ──────────────────────────────────────────────────────── #}
    <div class="card-modern mb-3">
        <h2 class="card-title" style="margin-bottom:1rem;">
            <i class="fas fa-sliders fa-fw" aria-hidden="true"></i>
            Builder
        </h2>

        <div class="cron-builder-grid" id="cron-builder">

            <div class="cron-builder-field">
                <div class="cron-builder-field-title">Minute <span class="cron-field-range">(0–59)</span></div>
                <select class="form-select form-select-sm" id="b-min-mode">
                    <option value="any">Toutes les minutes (*)</option>
                    <option value="step">Toutes les N minutes (*/N)</option>
                    <option value="specific" selected>Valeur précise</option>
                    <option value="range">Plage</option>
                    <option value="list">Liste</option>
                </select>
                <div id="b-min-inputs" class="cron-builder-inputs mt-2"></div>
            </div>

            <div class="cron-builder-field">
                <div class="cron-builder-field-title">Heure <span class="cron-field-range">(0–23)</span></div>
                <select class="form-select form-select-sm" id="b-hour-mode">
                    <option value="any" selected>Toutes les heures (*)</option>
                    <option value="step">Toutes les N heures (*/N)</option>
                    <option value="specific">Valeur précise</option>
                    <option value="range">Plage</option>
                    <option value="list">Liste</option>
                </select>
                <div id="b-hour-inputs" class="cron-builder-inputs mt-2"></div>
            </div>

            <div class="cron-builder-field">
                <div class="cron-builder-field-title">Jour du mois <span class="cron-field-range">(1–31)</span></div>
                <select class="form-select form-select-sm" id="b-dom-mode">
                    <option value="any" selected>Tous les jours (*)</option>
                    <option value="specific">Valeur précise</option>
                    <option value="range">Plage</option>
                    <option value="list">Liste</option>
                </select>
                <div id="b-dom-inputs" class="cron-builder-inputs mt-2"></div>
            </div>

            <div class="cron-builder-field">
                <div class="cron-builder-field-title">Mois <span class="cron-field-range">(1–12)</span></div>
                <select class="form-select form-select-sm" id="b-month-mode">
                    <option value="any" selected>Tous les mois (*)</option>
                    <option value="specific">Mois précis</option>
                    <option value="range">Plage</option>
                </select>
                <div id="b-month-inputs" class="cron-builder-inputs mt-2"></div>
            </div>

            <div class="cron-builder-field">
                <div class="cron-builder-field-title">Jour de semaine <span class="cron-field-range">(0=dim…6=sam)</span></div>
                <select class="form-select form-select-sm" id="b-dow-mode">
                    <option value="any" selected>Tous les jours (*)</option>
                    <option value="specific">Jour précis</option>
                    <option value="range">Plage</option>
                    <option value="list">Sélection</option>
                </select>
                <div id="b-dow-inputs" class="cron-builder-inputs mt-2"></div>
            </div>

        </div>
    </div>

    {# ── Raccourcis ───────────────────────────────────────────────────── #}
    <div class="card-modern">
        <h2 class="card-title" style="margin-bottom:0.75rem;">
            <i class="fas fa-bolt fa-fw" aria-hidden="true"></i>
            Raccourcis
        </h2>
        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-sm btn-outline-secondary cron-preset" data-expr="* * * * *">Toutes les minutes</button>
            <button class="btn btn-sm btn-outline-secondary cron-preset" data-expr="*/5 * * * *">Toutes les 5 min</button>
            <button class="btn btn-sm btn-outline-secondary cron-preset" data-expr="*/15 * * * *">Toutes les 15 min</button>
            <button class="btn btn-sm btn-outline-secondary cron-preset" data-expr="0 * * * *">Toutes les heures</button>
            <button class="btn btn-sm btn-outline-secondary cron-preset" data-expr="0 0 * * *">Tous les jours à minuit</button>
            <button class="btn btn-sm btn-outline-secondary cron-preset" data-expr="0 6 * * *">Tous les jours à 6h</button>
            <button class="btn btn-sm btn-outline-secondary cron-preset" data-expr="0 9-17 * * 1-5">Heure pile 9h–17h, lun–ven</button>
            <button class="btn btn-sm btn-outline-secondary cron-preset" data-expr="0 0 * * 1">Lundi à minuit</button>
            <button class="btn btn-sm btn-outline-secondary cron-preset" data-expr="0 2 * * 0">Dimanche à 2h</button>
            <button class="btn btn-sm btn-outline-secondary cron-preset" data-expr="0 3 1 * *">1er du mois à 3h</button>
            <button class="btn btn-sm btn-outline-secondary cron-preset" data-expr="30 23 * * 5">Vendredi à 23h30</button>
            <button class="btn btn-sm btn-outline-secondary cron-preset" data-expr="0 0 1 1 *">1er janvier à minuit</button>
        </div>
    </div>

</div>

<style nonce="{{ csp_nonce() }}">
.cron-desc-box {
    background: var(--color-bg-page);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.7rem 1rem;
    font-size: 0.9rem;
    color: var(--color-text-primary);
    min-height: 40px;
}
.cron-desc-box.error { color: var(--color-danger, #991B1B); }
.cron-fields-row {
    display: flex;
    gap: 0.25rem;
    align-items: center;
    flex-wrap: wrap;
}
.cron-field {
    background: var(--color-bg-page);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.5rem 0.75rem;
    text-align: center;
    min-width: 70px;
    cursor: default;
}
.cron-field-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--color-text-secondary); }
.cron-field-val   { font-family: monospace; font-size: 1.05rem; font-weight: 700; color: var(--color-primary); margin: 0.15rem 0; }
.cron-field-hint  { font-size: 0.6rem; color: var(--color-text-secondary); }
.cron-field-range { font-size: 0.75rem; font-weight: 400; color: var(--color-text-secondary); }
.cron-sep { color: var(--color-text-secondary); font-weight: 700; font-size: 1.1rem; padding: 0 2px; }
.cron-next-list {
    list-style: none;
    padding: 0; margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
}
.cron-next-list li {
    font-family: monospace;
    font-size: 0.88rem;
    color: var(--color-text-primary);
    background: var(--color-bg-page);
