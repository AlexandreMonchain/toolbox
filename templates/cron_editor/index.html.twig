</style>

<script nonce="{{ csp_nonce() }}">
(function () {

const MONTHS_FR = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
const DAYS_FR   = ['dimanche','lundi','mardi','mercredi','jeudi','vendredi','samedi'];

/* ── Parser cron part → sorted array, or null for * ─────────────────── */
function parsePart(val, vMin, vMax) {
    val = String(val).trim();
    if (val === '*') return null;
    const result = new Set();
    for (const seg of val.split(',')) {
        const stepM = seg.match(/^(\*|(\d+)-(\d+))\/(\d+)$/);
        if (stepM) {
            const step = Math.max(1, parseInt(stepM[4]));
            const from = stepM[2] !== undefined ? parseInt(stepM[2]) : vMin;
            const to   = stepM[3] !== undefined ? parseInt(stepM[3]) : vMax;
            for (let i = from; i <= to; i += step) result.add(i);
            continue;
        }
        const rngM = seg.match(/^(\d+)-(\d+)$/);
        if (rngM) {
            for (let i = parseInt(rngM[1]); i <= parseInt(rngM[2]); i++) result.add(i);
            continue;
        }
        if (/^\d+$/.test(seg)) { result.add(parseInt(seg)); continue; }
    }
    return [...result].sort((a, b) => a - b);
}

function matchPart(val, parsed, normalise0to7) {
    if (parsed === null) return true;
    if (normalise0to7 && val === 0 && parsed.includes(7)) return true;
    return parsed.includes(val);
}

/* ── Human description ──────────────────────────────────────────────── */
function describeField(raw, names, units) {
    raw = String(raw).trim();
    if (raw === '*') return null;

    const stepM = raw.match(/^\*\/(\d+)$/);
    if (stepM) return `toutes les ${stepM[1]} ${units[1] || ''}`.trim();

    const rngStepM = raw.match(/^(\d+)-(\d+)\/(\d+)$/);
    if (rngStepM) {
        const a = names ? (names[parseInt(rngStepM[1])] || rngStepM[1]) : rngStepM[1];
        const b = names ? (names[parseInt(rngStepM[2])] || rngStepM[2]) : rngStepM[2];
        return `toutes les ${rngStepM[3]} ${units[1] || ''} de ${a} à ${b}`.trim();
    }

    const rngM = raw.match(/^(\d+)-(\d+)$/);
    if (rngM) {
        const a = names ? (names[parseInt(rngM[1])] || rngM[1]) : rngM[1];
        const b = names ? (names[parseInt(rngM[2])] || rngM[2]) : rngM[2];
        return `de ${a} à ${b}`;
    }

    if (raw.includes(',')) {
        const parts = raw.split(',').map(p => {
            const n = parseInt(p);
            return names ? (names[n] || p) : p;
        });
        return parts.join(', ');
    }

    if (/^\d+$/.test(raw)) {
        const n = parseInt(raw);
        return names ? (names[n] || raw) : raw;
    }

    return raw;
}

function describe(expr) {
    expr = expr.trim();
    const specials = {
        '@reboot': 'Au démarrage du système',
        '@hourly': 'Toutes les heures, à heure pile',
        '@daily': 'Tous les jours à 00:00', '@midnight': 'Tous les jours à 00:00',
        '@weekly': 'Tous les dimanches à 00:00',
        '@monthly': 'Le 1er de chaque mois à 00:00',
        '@yearly': 'Le 1er janvier à 00:00', '@annually': 'Le 1er janvier à 00:00',
    };
    if (specials[expr]) return { ok: true, text: specials[expr] };

    const parts = expr.split(/\s+/);
    if (parts.length !== 5) return { ok: false, text: 'Expression invalide (5 champs attendus : min heure j/mois mois j/sem)' };

    const [minP, hourP, domP, monthP, dowP] = parts;

    const pieces = [];

    // Frequency
    if (minP === '*' && hourP === '*') {
        pieces.push('Toutes les minutes');
    } else {
        const minStep = minP.match(/^\*\/(\d+)$/);
        const hourStep = hourP.match(/^\*\/(\d+)$/);
        if (minStep) {
            pieces.push(`Toutes les ${minStep[1]} minute${parseInt(minStep[1]) > 1 ? 's' : ''}`);
        } else if (hourStep) {
            const mDesc = describeField(minP, null, ['minute','minutes']);
            const prefix = mDesc ? `à la minute ${mDesc}` : 'à heure pile';
            pieces.push(`Toutes les ${hourStep[1]} heure${parseInt(hourStep[1]) > 1 ? 's' : ''}, ${prefix}`);
        } else {
            // Build time string
            const mDesc   = describeField(minP, null, []);
            const hDesc   = describeField(hourP, null, []);
            if (hDesc && mDesc) {
                const hours = parsePart(hourP, 0, 23) || [];
                const mins  = parsePart(minP,  0, 59) || [];
                if (hours.length <= 4 && mins.length <= 4) {
                    const times = hours.map(h =>
                        mins.map(m => `${String(h).padStart(2,'0')}h${String(m).padStart(2,'0')}`).join(', ')
                    ).join(', ');
                    pieces.push(`À ${times}`);
                } else {
                    pieces.push(`À l'heure ${hDesc}, minute ${mDesc}`);
                }
            } else if (hDesc) {
                pieces.push(`À l'heure ${hDesc}`);
            } else if (mDesc) {
                pieces.push(`Chaque heure à la minute ${mDesc}`);
            }
        }
    }

    // Day of week
    if (dowP !== '*') {
        const dowDesc = describeField(dowP, DAYS_FR, ['jour','jours']);
        if (dowDesc) pieces.push(`le ${dowDesc}`);
    }

    // Day of month
    if (domP !== '*' && dowP === '*') {
        const domDesc = describeField(domP, null, ['jour','jours']);
        if (domDesc) {
            const n = parseInt(domP);
            if (/^\d+$/.test(domP)) pieces.push(`le ${n}${n === 1 ? 'er' : ''} du mois`);
            else pieces.push(`jours ${domDesc} du mois`);
        }
    }

    // Month
    if (monthP !== '*') {
        const mDesc = describeField(monthP, MONTHS_FR, ['mois','mois']);
        if (mDesc) pieces.push(`en ${mDesc}`);
    }

    return { ok: true, text: pieces.join(', ') || 'Expression vide' };
}

/* ── Next runs ───────────────────────────────────────────────────────── */
function nextRuns(expr, count) {
    const parts = expr.trim().split(/\s+/);
    if (parts.length !== 5) return [];
    const [minP, hourP, domP, monthP, dowP] = parts;

    const pMin   = parsePart(minP,   0, 59);
    const pHour  = parsePart(hourP,  0, 23);
    const pDom   = parsePart(domP,   1, 31);
    const pMonth = parsePart(monthP, 1, 12);
    const pDow   = parsePart(dowP,   0, 7);

    const results = [];
    const d = new Date();
    d.setSeconds(0, 0);
    d.setMinutes(d.getMinutes() + 1);

    const MAX = 527040; // 366 days
    for (let i = 0; i < MAX && results.length < count; i++) {
        if (
            matchPart(d.getMinutes(),     pMin,   false) &&
            matchPart(d.getHours(),       pHour,  false) &&
            matchPart(d.getDate(),        pDom,   false) &&
            matchPart(d.getMonth() + 1,   pMonth, false) &&
            matchPart(d.getDay(),         pDow,   true)
        ) {
            results.push(new Date(d));
        }
        d.setMinutes(d.getMinutes() + 1);
    }
    return results;
}

/* ── UI update ───────────────────────────────────────────────────────── */
function updateFromExpr(expr) {
    const parts = expr.trim().split(/\s+/);

    // Field badges
    const ids = ['min','hour','dom','month','dow'];
    ids.forEach((id, i) => {
        const el = document.getElementById('cfv-' + id);
        if (el) el.textContent = parts[i] || '?';
    });

    // Description
    const desc = describe(expr);
    const descEl = document.getElementById('cron-desc');
    descEl.textContent = desc.text;
    descEl.className = 'cron-desc-box' + (desc.ok ? '' : ' error');

    // Next runs
    const ol = document.getElementById('cron-next');
    ol.innerHTML = '';
    if (desc.ok) {
        const runs = nextRuns(expr, 5);
        if (runs.length === 0) {
            const li = document.createElement('li');
            li.textContent = 'Aucune exécution trouvée dans l\'année à venir.';
            li.style.color = 'var(--color-text-secondary)';
            ol.appendChild(li);
        } else {
            runs.forEach(d => {
                const li = document.createElement('li');
                li.textContent = d.toLocaleString('fr-FR', {
                    weekday:'short', year:'numeric', month:'2-digit', day:'2-digit',
                    hour:'2-digit', minute:'2-digit'
                });
                ol.appendChild(li);
            });
        }
    }
}

/* ── Builder ─────────────────────────────────────────────────────────── */
const FIELDS = [
    { id: 'min',   vMin: 0,  vMax: 59, unit: 'minutes', names: null },
    { id: 'hour',  vMin: 0,  vMax: 23, unit: 'heures',  names: null },
    { id: 'dom',   vMin: 1,  vMax: 31, unit: 'jours',   names: null },
    { id: 'month', vMin: 1,  vMax: 12, unit: 'mois',    names: ['','janv.','févr.','mars','avr.','mai','juin','juil.','août','sept.','oct.','nov.','déc.'] },
    { id: 'dow',   vMin: 0,  vMax: 6,  unit: 'jours',   names: ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'] },
];

let builderUpdating = false;

function renderBuilderInputs(field) {
    const mode    = document.getElementById(`b-${field.id}-mode`).value;
    const wrapper = document.getElementById(`b-${field.id}-inputs`);
    wrapper.innerHTML = '';

    function numInput(id, val, min, max, label) {
        const lbl = document.createElement('label');
        lbl.style.fontSize = '0.8rem';
        lbl.style.display  = 'flex';
        lbl.style.alignItems = 'center';
        lbl.style.gap = '0.4rem';
        lbl.style.marginTop = '0.3rem';
        if (label) { const t = document.createTextNode(label + ' '); lbl.appendChild(t); }
        const inp = document.createElement('input');
        inp.type  = 'number'; inp.id = id; inp.value = val;
        inp.min   = min; inp.max = max;
        inp.className = 'form-control form-control-sm';
        inp.style.width = '80px';
        inp.addEventListener('input', buildFromBuilder);
        lbl.appendChild(inp);
        wrapper.appendChild(lbl);
    }

    if (mode === 'any') return;

    if (mode === 'step') {
        numInput(`b-${field.id}-step`, 5, 1, field.vMax - field.vMin);
    } else if (mode === 'specific') {
        if (field.names) {
            const sel = document.createElement('select');
            sel.id        = `b-${field.id}-val`;
            sel.className = 'form-select form-select-sm mt-1';
            for (let i = field.vMin; i <= field.vMax; i++) {
                const opt = document.createElement('option');
                opt.value = i; opt.textContent = (field.names[i] || i);
                sel.appendChild(opt);
            }
            sel.addEventListener('change', buildFromBuilder);
            wrapper.appendChild(sel);
        } else {
            numInput(`b-${field.id}-val`, field.vMin, field.vMin, field.vMax);
        }
    } else if (mode === 'range') {
        numInput(`b-${field.id}-from`, field.vMin, field.vMin, field.vMax, 'De');
        numInput(`b-${field.id}-to`,   field.vMax, field.vMin, field.vMax, 'à');
    } else if (mode === 'list') {
        if (field.names) {
            const wrap = document.createElement('div');
            wrap.style.display = 'flex'; wrap.style.flexWrap = 'wrap'; wrap.style.gap = '0.35rem'; wrap.style.marginTop = '0.5rem';
            for (let i = field.vMin; i <= field.vMax; i++) {
                const lbl = document.createElement('label');
                lbl.style.cssText = 'font-size:0.78rem; display:flex; align-items:center; gap:0.25rem; cursor:pointer;';
                const cb = document.createElement('input'); cb.type = 'checkbox'; cb.value = i;
                cb.id = `b-${field.id}-cb-${i}`;
                cb.addEventListener('change', buildFromBuilder);
                lbl.appendChild(cb);
                lbl.appendChild(document.createTextNode(field.names[i] || i));
                wrap.appendChild(lbl);
            }
            wrapper.appendChild(wrap);
        } else {
            const inp = document.createElement('input');
            inp.type = 'text'; inp.id = `b-${field.id}-list`;
            inp.placeholder = `ex: 0,15,30,45`;
            inp.className = 'form-control form-control-sm mt-1';
            inp.addEventListener('input', buildFromBuilder);
            wrapper.appendChild(inp);
        }
    }
}

function fieldPartFromBuilder(field) {
    const mode = document.getElementById(`b-${field.id}-mode`).value;
    if (mode === 'any') return '*';
    if (mode === 'step') {
        const v = document.getElementById(`b-${field.id}-step`);
        return v ? `*/${v.value}` : '*';
    }
    if (mode === 'specific') {
        const v = document.getElementById(`b-${field.id}-val`);
        return v ? v.value : field.vMin;
    }
    if (mode === 'range') {
        const f = document.getElementById(`b-${field.id}-from`);
        const t = document.getElementById(`b-${field.id}-to`);
        return (f && t) ? `${f.value}-${t.value}` : '*';
    }
    if (mode === 'list') {
        if (field.names) {
            const checked = [];
            for (let i = field.vMin; i <= field.vMax; i++) {
                const cb = document.getElementById(`b-${field.id}-cb-${i}`);
                if (cb && cb.checked) checked.push(i);
            }
            return checked.length ? checked.join(',') : '*';
        } else {
            const inp = document.getElementById(`b-${field.id}-list`);
            return (inp && inp.value.trim()) ? inp.value.trim() : '*';
        }
    }
    return '*';
}

function buildFromBuilder() {
    if (builderUpdating) return;
    const parts = FIELDS.map(f => fieldPartFromBuilder(f));
    const expr = parts.join(' ');
    document.getElementById('cron-expr').value = expr;
    updateFromExpr(expr);
}

FIELDS.forEach(f => {
    const sel = document.getElementById(`b-${f.id}-mode`);
    sel.addEventListener('change', () => {
        renderBuilderInputs(f);
        buildFromBuilder();
    });
    renderBuilderInputs(f);
});

/* ── Presets ─────────────────────────────────────────────────────────── */
document.querySelectorAll('.cron-preset').forEach(btn => {
    btn.addEventListener('click', () => {
        const expr = btn.dataset.expr;
        document.getElementById('cron-expr').value = expr;
        updateFromExpr(expr);
    });
});

/* ── Main expression input ───────────────────────────────────────────── */
document.getElementById('cron-expr').addEventListener('input', function () {
    updateFromExpr(this.value);
});

/* ── Copy ────────────────────────────────────────────────────────────── */
document.getElementById('cron-copy').addEventListener('click', () => {
    const expr = document.getElementById('cron-expr').value;
    navigator.clipboard.writeText(expr).then(() => {
        const btn = document.getElementById('cron-copy');
        const orig = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-check" aria-hidden="true"></i>';
        setTimeout(() => { btn.innerHTML = orig; }, 1200);
    }).catch(() => {});
});

/* ── Init ────────────────────────────────────────────────────────────── */
updateFromExpr(document.getElementById('cron-expr').value);

})();
</script>
{% endblock %}
